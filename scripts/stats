#!/bin/bash
# SAYLESS Stats Dashboard
set -e

SERVER="root@37.27.252.86"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

if [ "$1" = "--prod" ]; then
    DB="/tmp/sayless-prod.db"
    scp -q "$SERVER:/var/lib/sayless/sayless.db" "$DB"
elif [ -n "$1" ]; then
    DB="$1"
else
    DB="$PROJECT_DIR/sayless.db"
fi

echo "=== SAYLESS Stats ==="
echo "db: $DB"
echo ""
echo "Mailing list: $(sqlite3 "$DB" 'SELECT COUNT(*) FROM subscribers;') subscribers"
echo ""
echo "Recent signups:"
sqlite3 -header -column "$DB" \
  "SELECT email, created_at FROM subscribers ORDER BY created_at DESC LIMIT 10;"
